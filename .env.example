# Foyer environment configuration

# Encryption key for secrets at rest (AES-256-GCM).
# Must be at least 32 bytes. In production, generate a strong random key.
# In development, if omitted, a static dev fallback is used with a console warning.
FOYER_ENCRYPTION_KEY=

# Database configuration
# Set to 'false' to use PostgreSQL instead of PGlite (default)
DATABASE_LITE=true
DATABASE_LITE_PATH=services/engine/data/pglite/
DATABASE_URL=

# Engine port
PORT=3301
